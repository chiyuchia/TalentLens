FLASK_ENV=development
FLASK_SECRET_KEY=dev-secret-change-me
APP_ACCESS_KEY=talentlens-dev-key
DATABASE_URL=sqlite:///talentlens.sqlite3
UPLOAD_DIR=instance/uploads
AI_MODE=mock
AI_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# Moonshot / Kimi
# Kimi for Coding (https://www.kimi.com/code/docs/):
#   MOONSHOT_BASE_URL=https://api.kimi.com/coding/v1
#   MOONSHOT_MODEL=kimi-for-coding
# Standard Moonshot:
#   MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
#   MOONSHOT_MODEL=moonshot-v1-8k
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.kimi.com/coding/v1
MOONSHOT_MODEL=kimi-for-coding
SESSION_COOKIE_SECURE=false
