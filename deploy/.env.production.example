FLASK_ENV=production
APP_ACCESS_KEY=replace-with-a-long-random-access-key
FLASK_SECRET_KEY=replace-with-a-long-random-flask-secret
AI_MODE=mock
AI_PROVIDER=openai

# Cross-origin config (required for CF Pages frontend + VPS backend)
FRONTEND_ORIGIN=https://your-cf-pages-domain.pages.dev
SESSION_COOKIE_SAMESITE=None
SESSION_COOKIE_SECURE=true

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# Moonshot (Kimi)
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.kimi.com/coding/v1
MOONSHOT_MODEL=kimi-for-coding

